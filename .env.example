# ── Required ──────────────────────────────────────────────────────────────────
# Must be at least 32 characters.
JWT_SECRET=replace-with-a-32-character-minimum-secret-key

MYSQL_ROOT_PASSWORD=devboard-root
MYSQL_PASSWORD=devboard

# ── Optional ──────────────────────────────────────────────────────────────────
# Redis password — leave blank if your Redis instance has no auth (default for
# the bundled docker-compose Redis service).
REDIS_PASSWORD=
